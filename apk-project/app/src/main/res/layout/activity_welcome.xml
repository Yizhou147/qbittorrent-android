<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="qBittorrent"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#1D7DD4"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="欢迎使用，请选择你的 WebUI"
            android:textSize="15sp"
            android:textColor="#666666"
            android:layout_marginBottom="28dp" />

        <!-- WebUI 选择 -->
        <LinearLayout
            android:id="@+id/cardVuetorrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VueTorrent (推荐)"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="现代化 WebUI，暗色主题，PWA，移动端优化"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardDefault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认 WebUI"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="qBittorrent 原版 WebUI，经典布局"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 端口设置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WebUI 端口"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etWelcomePort"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:text="8080"
            android:textSize="16sp"
            android:background="@drawable/card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="16dp" />

        <!-- 下载路径 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="默认下载路径"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etWelcomePath"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="text"
            android:textSize="14sp"
            android:singleLine="true"
            android:background="@drawable/card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="28dp" />

        <!-- 开始按钮 -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开始使用"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1D7DD4"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="后续可在「设置」中修改"
            android:textSize="12sp"
            android:textColor="#aaaaaa" />

    </LinearLayout>
</ScrollView>
